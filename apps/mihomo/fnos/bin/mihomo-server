#!/bin/bash
# fnOS launcher: starts mihomo (internal 127.0.0.1:9090) + fnos-mihomo-dashboard
# (the fnOS-facing port). Dashboard manages config.yaml + reverse-proxies mihomo,
# so we never expose mihomo directly to the LAN; external-controller stays internal.
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

CONF_DIR="$APP_DATA_DIR/config"
CONFIG_FILE="$CONF_DIR/config.yaml"
LOG_FILE="$APP_DATA_DIR/mihomo.log"
MIHOMO_PID_FILE="$APP_DATA_DIR/mihomo-kernel.pid"
UI_DIR="$APP_DIR/metacubexd"

mkdir -p "$CONF_DIR"

log_msg() {
    printf '[mihomo-server] %s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" | tee -a "$LOG_FILE" >&2
}

# First-run minimal config: dashboard will mutate proxy-providers/proxy-groups as
# the user sets subscription URL. external-controller stays bound to localhost.
if [ ! -f "$CONFIG_FILE" ]; then
    log_msg "First run: writing minimal config.yaml"
    cat > "$CONFIG_FILE" <<YAML
mixed-port: 7890
allow-lan: true
bind-address: '*'
mode: rule
log-level: info
ipv6: false

external-controller: 127.0.0.1:9090
secret: ""

dns:
  enable: true
  listen: 127.0.0.1:1053
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 223.5.5.5
    - 119.29.29.29

tun:
  enable: false
  stack: system
  auto-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53

proxies: []

proxy-groups:
  - name: "PROXY"
    type: select
    proxies:
      - DIRECT

rules:
  - MATCH,PROXY
YAML
fi

# Cleanup any leftover mihomo from a crash
if [ -f "$MIHOMO_PID_FILE" ]; then
    OLD_PID=$(cat "$MIHOMO_PID_FILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        kill "$OLD_PID" 2>/dev/null
        sleep 1
        kill -9 "$OLD_PID" 2>/dev/null
    fi
    rm -f "$MIHOMO_PID_FILE"
fi

# Start mihomo in background (binds 127.0.0.1:9090 only)
log_msg "Starting mihomo (internal 127.0.0.1:9090)"
cd "$APP_DIR" || exit 1
./mihomo -d "$CONF_DIR" >> "$LOG_FILE" 2>&1 &
echo $! > "$MIHOMO_PID_FILE"

# Wait briefly for mihomo to be ready
sleep 2

# Start dashboard as foreground (fnOS PID file tracks this)
log_msg "Starting fnos-mihomo-dashboard on :${TRIM_SERVICE_PORT}"
exec "$APP_DIR/fnos-mihomo-dashboard" \
    -listen ":${TRIM_SERVICE_PORT}" \
    -mihomo-api "http://127.0.0.1:9090" \
    -config "$CONFIG_FILE" \
    -log "$LOG_FILE" \
    -metacubexd "$UI_DIR"
