#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

# fnOS-tracked PID = fnos-mihomo-dashboard (foreground).
# mihomo runs as backgrounded child with its own PID in mihomo.pid.
SERVICE_COMMAND="$APP_DIR/bin/mihomo-server $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y
SVC_WAIT_TIMEOUT=30

# Grant mihomo binary the capabilities needed for TUN mode (CAP_NET_ADMIN/RAW/BIND_SERVICE).
service_postinst() {
    if command -v setcap >/dev/null 2>&1; then
        setcap 'cap_net_admin,cap_net_raw,cap_net_bind_service+ep' \
            "${TRIM_APPDEST}/mihomo" 2>/dev/null || \
            echo "WARN: setcap failed; TUN mode may require manual setup" >> "${LOG_FILE}"
    fi
}
service_postupgrade() { service_postinst; }

service_preuninst() {
    # Kill mihomo subprocess via its private PID file first
    if [ -f "${TRIM_PKGVAR}/mihomo-kernel.pid" ]; then
        kill "$(cat "${TRIM_PKGVAR}/mihomo-kernel.pid")" 2>/dev/null
        sleep 1
        kill -9 "$(cat "${TRIM_PKGVAR}/mihomo-kernel.pid")" 2>/dev/null
        rm -f "${TRIM_PKGVAR}/mihomo-kernel.pid"
    fi
    # Sweep both binaries by name (-x for exact match, avoids killing appcenter-cli args)
    pkill -x "fnos-mihomo-dashboard" 2>/dev/null || true
    pkill -x "mihomo" 2>/dev/null || true
    sleep 1
    pkill -9 -x "fnos-mihomo-dashboard" 2>/dev/null || true
    pkill -9 -x "mihomo" 2>/dev/null || true
}

service_poststop() { service_preuninst; }
