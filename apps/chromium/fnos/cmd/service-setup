#!/bin/bash

# Sanitize a wizard password into a value safe for .env / docker-compose.
# - strips ALL whitespace (newlines, tabs, spaces would break .env parsing)
# - removes characters that would be interpreted by docker-compose:
#     $ (env var expansion), " ' \` (quoting), # (comment), \ (escape)
# - truncates to 8 chars (VNC protocol hard limit; everything past is ignored)
# Returns empty string if nothing survives.
sanitize_vnc_password() {
    local raw="$1"
    # 1) strip newlines/tabs/spaces
    raw="${raw//[[:space:]]/}"
    # 2) keep only printable ASCII minus shell/dotenv-hostile characters
    local safe=""
    local i ch
    for (( i=0; i<${#raw} && i<8; i++ )); do
        ch="${raw:$i:1}"
        case "$ch" in
            [\$\"\'\`\#\\]) ;;
            *) safe="${safe}${ch}" ;;
        esac
    done
    printf '%s' "$safe"
}

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"

    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/fonts" 2>/dev/null || true

    # ALWAYS write .env, even if user did not supply a password.
    # docker-compose.yaml declares \`env_file: [.env]\` so the file MUST exist
    # (otherwise compose fails). We write VNC_PASSWORD=\"\" by default which leaves
    # the GUI unprotected (jlesage default behavior), and overwrite with the
    # sanitized wizard value when present.
    local clean=""
    if [ -n "${wizard_password}" ]; then
        clean="$(sanitize_vnc_password "${wizard_password}")"
        if [ -z "$clean" ]; then
            install_log "wizard_password contained only invalid characters; VNC auth NOT enabled"
        fi
    fi
    cat > "$env_file" <<EOF
# Written by service_postinst at install time.
# Edit VNC_PASSWORD below and restart Chromium to change the access password.
VNC_PASSWORD=${clean}
EOF
    chmod 600 "$env_file"
    if [ -n "$clean" ]; then
        install_log "Wrote docker .env: VNC_PASSWORD set (sanitized length=${#clean})"
    else
        install_log "Wrote docker .env: VNC_PASSWORD empty (no auth, Chromium open to anyone reaching port)"
    fi
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:5800"/"'"${port}"':5800"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
